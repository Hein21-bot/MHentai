# Server
PORT=8080
ADMIN_TOKEN=admin123

# AWS DynamoDB
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: local DynamoDB (comment out for real AWS)
# DYNAMODB_ENDPOINT=http://localhost:8000

# Optional: custom table names (defaults shown)
# DYNAMODB_TABLE_SERIES=mhentai_series
# DYNAMODB_TABLE_CHAPTERS=mhentai_chapters

# Cloudflare R2 (optional — leave blank to skip image hosting)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mhentai
R2_PUBLIC_URL=
